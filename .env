# LLM Provider Configuration
LLM_PROVIDER=GEMINI
GEMINI_API_KEY=key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=16384

# If you want to switch to OpenAI, uncomment these and comment out Gemini settings:
# LLM_PROVIDER=OPENAI
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Database Configuration
DATABASE_URL=sqlite:///./resume_editor.db
ENVIRONMENT=development

# Job Search API Configuration
# JSearch API (OpenWebNinja) - Active API key for testing
JSEARCH_API_KEY=api_key_here
